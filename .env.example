# Public site name (optional; defaults to Envowl)
NEXT_PUBLIC_PLATFORM_NAME=Envowl

# Beehiiv — Create Subscription API (https://developers.beehiiv.com)
# Publication: https://goenvowl.beehiiv.com — copy the prefixed Publication ID from
# Beehiiv → Settings → API (e.g. pub_xxxxxxxx).
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Optional: Supabase (legacy waitlist table — not used by /api/subscribe)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
